# Copia questo file in .env e inserisci la tua chiave personale.
# .env NON va committato (gitignored).

# Chiave del provider scelto. litellm legge le env var standard:
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
#   GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# Modello in formato litellm (opzionale). Default: anthropic/claude-sonnet-4-6
# Esempi: openai/gpt-4o, gemini/gemini-2.0-flash
# CICERONE_MODEL=anthropic/claude-sonnet-4-6
